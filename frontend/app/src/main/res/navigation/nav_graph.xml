<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment"> <fragment
    android:id="@+id/onboardingFragment"
    android:name="com.example.application.features.onboarding.OnboardingFragment"
    tools:layout="@layout/fragment_onboarding">
    <action
        android:id="@+id/action_onboarding_to_auth"
        app:destination="@id/authFragment"
        app:popUpTo="@id/onboardingFragment"
        app:popUpToInclusive="true" /> </fragment>

    <fragment
        android:id="@+id/authFragment"
        android:name="com.example.application.features.authentication.AuthFragment"
        android:label="Connexion"
        tools:layout="@layout/fragment_auth">
        <action
            android:id="@+id/action_auth_to_feed"
            app:destination="@id/feedFragment"
            app:popUpTo="@id/authFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.application.features.discovery.SearchFragment"
        tools:layout="@layout/fragment_search" />

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.example.application.features.discovery.FeedFragment">
        <action
            android:id="@+id/action_feed_to_search"
            app:destination="@id/searchFragment" />
    </fragment>

    <fragment
        android:id="@+id/createPostFragment"
        android:name="com.example.application.features.post.CreatePostFragment"
        android:label="Nouveau Post"
        tools:layout="@layout/fragment_create_post" />

    <fragment
        android:id="@+id/socialFragment"
        android:name="com.example.application.features.social.SocialFragment"
        android:label="Social"
        tools:layout="@layout/fragment_social">
        <action
            android:id="@+id/action_social_to_createGroup"
            app:destination="@id/createGroupFragment" />
    </fragment>

    <fragment
        android:id="@+id/createGroupFragment"
        android:name="com.example.application.features.social.CreateGroupFragment"
        android:label="Nouveau Groupe"
        tools:layout="@layout/fragment_create_group" />

    <fragment
        android:id="@+id/itineraryFragment"
        android:name="com.example.application.features.path.PathFragment"
        android:label="Vos Parcours"
        tools:layout="@layout/fragment_path" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.application.features.profile.ProfileFragment"
        android:label="Profil"
        tools:layout="@layout/fragment_profile">

        <action
            android:id="@+id/action_profile_to_auth"
            app:destination="@id/authFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/createPathFragment"
        android:name="com.example.application.features.path.CreatePathFragment"
        android:label="Personnalisation"
        tools:layout="@layout/fragment_create_path">

        <action
            android:id="@+id/action_createPath_to_results"
            app:destination="@id/pathResultsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left" />
    </fragment>

    <fragment
        android:id="@+id/pathResultsFragment"
        android:name="com.example.application.features.path.PathResultsFragment"
        android:label="Choix du parcours"
        tools:layout="@layout/fragment_path_results" />

</navigation>