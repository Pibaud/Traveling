<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/white"
            app:title="Nouveau Groupe">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPublishGroup"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Créer"
                android:textColor="#7A1C2A"
                android:textStyle="bold"
                android:enabled="false"/>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <FrameLayout
                android:id="@+id/flGroupPhoto"
                android:layout_width="140dp"
                android:layout_height="140dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivGroupPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#E0E0E0"
                    app:cornerSize="24dp" />

                <ImageView
                    android:id="@+id/ivAddPhotoIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@drawable/round_add_photo_alternate_24"
                    app:tint="#7A1C2A" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvAddPhotoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ajouter une couverture"
                android:textColor="#7A1C2A"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/flGroupPhoto"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilGroupName"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:hint="Nom du groupe"
                app:layout_constraintTop_toBottomOf="@id/tvAddPhotoLabel">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etGroupName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLength="50"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilGroupDesc"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Description"
                app:layout_constraintTop_toBottomOf="@id/tilGroupName">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etGroupDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:gravity="top"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvPrivacyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confidentialité"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/tilGroupDesc"
                app:layout_constraintStart_toStartOf="parent"/>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchPrivacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Groupe public"
                android:textSize="16sp"
                android:checked="true"
                app:layout_constraintTop_toBottomOf="@id/tvPrivacyTitle" />
            <TextView
                android:id="@+id/tvPrivacyDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N'importe qui peut trouver et rejoindre ce groupe."
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/switchPrivacy"/>

            <TextView
                android:id="@+id/tvTagsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thèmes du groupe (Max 3)"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/tvPrivacyDesc"
                app:layout_constraintStart_toStartOf="parent"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupThemes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleSelection="false"
                app:layout_constraintTop_toBottomOf="@id/tvTagsTitle"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>